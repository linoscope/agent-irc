# Per-chapter Ergo state (regenerated by start-ergo.sh on every run)
**/data/

# Foundry build artifacts (chapters 08+)
**/cache/
**/out/

# Per-chapter deploy outputs
**/.registry-address

# Compiled Go binaries that some chapters drop next to source
.ch*-server
**/.ch*-server
**/01-hello-irc/01-hello-irc
**/02-channels/02-channels
**/verify/verify
**/.venv/

# Runtime artifacts (regenerated by verify*.sh and friends)
**/*.jsonl
**/__pycache__/
**/ircd.lock

# Wallet secrets (private keys, funded testnet/mainnet creds). NEVER commit.
.env
**/.env
*.key
**/keys/*.key

# Per-chapter deploy outputs (runtime-only; deploy.sh writes them)
**/.*-agentid

# ircd.yaml is regenerated deterministically by each chapter's start-ergo*.sh
# from `ergo defaultconfig` — the script-managed source of truth — so the
# checked-in version drifts every run and shouldn't be tracked past ch04.
05*/ircd.yaml
06*/ircd.yaml
07*/ircd.yaml
08*/ircd.yaml
09*/ircd.yaml
10*/ircd.yaml
11*/ircd.yaml

# Claude Code session-local state
/.claude/

# GoReleaser output
/dist/
# stray go-build output at monorepo root
/agent-irc
